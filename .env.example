# Core runtime
DATABASE_URL="postgres://postgres:postgres@localhost:5432/motocheck"
NHTSA_API_URL="https://vpic.nhtsa.dot.gov/api"
PUBLIC_BASE_URL="http://localhost:5173"
NODE_ENV="development"

# Payments and notifications
PAYSTACK_SECRET_KEY="sk_test_your_paystack_secret_key"
RESEND_API_KEY="re_your_resend_api_key"
FROM_EMAIL="MotoCheck <noreply@example.com>"
ADMIN_EMAIL="admin@example.com"
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_SECRET_TOKEN="your_telegram_secret_token"

# Optional LLM configuration
# If no provider key is configured, the pipeline falls back to deterministic
# analysis and section generation.
LLM_PROVIDER="alibaba"
ALIBABA_API_KEY=""
ALIBABA_MODEL="qwen-plus"
MULEROUTER_API_KEY=""
MULEROUTER_MODEL="qwen-flash"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemma-4-26b-a4b-it:free"

# Optional paid / enrichment providers
NMVTIS_API_URL=""
NMVTIS_API_KEY=""
NICB_API_URL="https://www.nicb.org/vincheck/api"
NICB_API_KEY=""

# Optional image search enrichment
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_ENGINE_ID=""

# Worker tuning
WORKER_CONCURRENCY="5"
SCRAPER_CONCURRENCY="2"

# Local helpers
API_BASE_URL="http://localhost:5173"
