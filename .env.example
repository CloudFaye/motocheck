# ============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# ============================================================================

# Database (PostgreSQL connection string)
# Required for both web app and worker process
DATABASE_URL=${{ Postgres.DATABASE_URL }}

# LLM Provider Selection (gemini or anthropic)
# Default: gemini (free tier available)
LLM_PROVIDER="gemini"

# Google Gemini API (for LLM analysis and section writing)
# Get your free API key from: https://makersuite.google.com/app/apikey
# Free tier: 15 requests/minute, 1M tokens/day
GEMINI_API_KEY="your_gemini_api_key"

# Anthropic API (Claude LLM - premium alternative)
# Only required if LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY="sk-ant-your_anthropic_api_key"

# NMVTIS Provider (for official title history)
# Required for NMVTIS fetcher worker
NMVTIS_API_URL="https://your-nmvtis-provider.com/api/v1/vehicle"
NMVTIS_API_KEY="your_nmvtis_api_key"

# Node Environment (development, production, test)
# Required for environment-specific behavior
NODE_ENV="development"

# ============================================================================
# OPTIONAL ENVIRONMENT VARIABLES
# ============================================================================

# NICB VINCheck API (for theft records)
# Optional - if not provided, theft checking will be skipped
NICB_API_KEY="your_nicb_api_key"

# LLM Model Selection
# Optional - defaults based on provider
# For Gemini: gemini-1.5-flash (default), gemini-1.5-pro
# For Anthropic: claude-sonnet-4-20250514 (default)
GEMINI_MODEL="gemini-1.5-flash"
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# Worker Concurrency (number of concurrent jobs per worker type)
# Optional - defaults to pg-boss defaults
WORKER_CONCURRENCY="5"

# Scraper Concurrency (number of concurrent browser instances)
# Optional - defaults to 2 for rate-limited scrapers
SCRAPER_CONCURRENCY="2"

# ============================================================================
# EXISTING CONFIGURATION (preserved)
# ============================================================================

# NHTSA API
NHTSA_API_URL="https://vpic.nhtsa.dot.gov/api"

# Paystack Payment Gateway
PAYSTACK_SECRET_KEY="sk_test_your_paystack_secret_key"

# Resend Email Service
RESEND_API_KEY="your_resend_api_key"
FROM_EMAIL="noreply@yourdomain.com"

# Admin Email (for worker notifications and monitoring)
ADMIN_EMAIL="admin@yourdomain.com"

# Cloudflare R2 Storage (keep bucket PRIVATE)
R2_ENDPOINT="https://your_account_id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_r2_bucket_name"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_SECRET_TOKEN="your_telegram_secret_token"

# Google Custom Search API (for vehicle images)
GOOGLE_SEARCH_API_KEY="your_google_api_key"
GOOGLE_SEARCH_ENGINE_ID="your_search_engine_id"

# Application
PUBLIC_BASE_URL="http://localhost:5173"

# API Base URL (for testing scripts)
# Optional - defaults to http://localhost:5173
API_BASE_URL="http://localhost:5173"

# NICB VINCheck API URL
NICB_API_URL="https://www.nicb.org/vincheck/api"


