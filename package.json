{
	"name": "motocheck",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently \"vite dev\" \"pnpm workers\"",
		"dev:web": "vite dev",
		"workers": "tsx workers/index.ts",
		"workers:prod": "node --import tsx workers/index.ts",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest --run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:clear-invalid": "source .env && psql \"$DATABASE_URL\" -f clear-invalid-vins.sql",
		"generate:sample-pdf": "npx tsx generate-sample-pdf.ts",
		"bot:setup": "tsx src/telegram-bot/start.ts",
		"test:vin": "tsx scripts/test-vin.ts"
	},
	"devDependencies": {
		"@eslint/compat": "latest",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/geist": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "latest",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tabler/icons-svelte": "^3.40.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^22",
		"@vitest/ui": "^4.1.1",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"mode-watcher": "^1.1.0",
		"postgres": "^3.4.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.1"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.82.0",
		"@aws-sdk/client-s3": "^3.1017.0",
		"@aws-sdk/s3-request-presigner": "^3.1017.0",
		"@google/generative-ai": "^0.24.1",
		"@types/pdfkit": "^0.17.5",
		"docx": "^9.6.1",
		"got": "^15.0.0",
		"openai": "^6.33.0",
		"pdfkit": "^0.18.0",
		"pg-boss": "^12.15.0",
		"puppeteer": "^24.40.0",
		"puppeteer-extra": "^3.3.6",
		"puppeteer-extra-plugin-stealth": "^2.11.2",
		"resend": "^6.9.4",
		"telegraf": "^4.16.3"
	}
}
